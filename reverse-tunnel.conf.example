# Имя системного пользователя, от которого работает туннель
TUNNEL_USER="tunnel-c1"

# Адрес назначения (user@host) — ВСЕГДА последний аргумент SSH
# Примеры:
#   SSH_DESTINATION="user@server.example.com"
#   SSH_DESTINATION="nedlosster@38.135.122.149"
SSH_DESTINATION="user@server.example.com"

# Порт на СЕРВЕРЕ, через который будет доступна станция
# (ssh -R 127.0.0.1:<TUNNEL_PORT>:127.0.0.1:22 ...)
TUNNEL_PORT=2232

# Дополнительные SSH-опции (ProxyJump, IPv4, agent forwarding и пр.)
# Примеры:
#   SSH_EXTRA_OPTS="-4 -J root@nlproxy"
#   SSH_EXTRA_OPTS="-4 -J root@nlproxy -A -o ServerAliveInterval=60"
#   SSH_EXTRA_OPTS="-p 2222 -J user@jumphost.example.com:2200"
SSH_EXTRA_OPTS=""
