# ssh-tunnel-2local — конфигурация
# Скопируй в config.yml и отредактируй

remote:
  host: 203.0.113.10            # Внешний IP публичного сервера
  user: admin                   # SSH-юзер для настройки (с sudo)
  ssh_port: 22                  # SSH-порт для управления

tunnel_user: tunnel             # Пользователь для туннеля (создаётся на обоих серверах)

ports:
  # Веб-сервер
  - public: 80
    local: 80
    name: HTTP

  - public: 443
    local: 443
    name: HTTPS

  # Проброс на другой хост в LAN (без PROXY protocol)
  # - public: 2222
  #   local: 2222
  #   name: GitLab-SSH
  #   target: "192.168.0.28:2222"
  #   no_proxy_protocol: true

# --- Необязательные параметры (значения по умолчанию) ---

# tunnel_port_offset: 10000      # Смещение портов в туннеле (80 → 10080)
# tunnel_ssh_port: 22            # SSH-порт для туннельного соединения
# keepalive_interval: 30         # SSH ServerAliveInterval (сек)
# keepalive_count: 3             # SSH ServerAliveCountMax
# autossh_poll: 600              # Интервал проверки autossh (сек)
# autossh_first_poll: 30         # Первая проверка autossh (сек)
# autossh_gate_time: 30          # Минимальное время работы до рестарта (сек)
# monitor_check_interval: 60    # Интервал проверки мониторинга (сек)
# monitor_max_failures: 3       # Отказов до перезапуска
# restart_delay: 10              # Задержка перезапуска (сек)
# log_dir: /var/log/ssh-tunnel   # Директория логов
