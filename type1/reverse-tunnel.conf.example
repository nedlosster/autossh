# Имя системного пользователя, от которого работает туннель
TUNNEL_USER="tunnel-c1"

# Адрес назначения (user@host) — ВСЕГДА последний аргумент SSH
# Примеры:
#   SSH_DESTINATION="user@server.example.com"
#   SSH_DESTINATION="nedlosster@38.135.122.149"
SSH_DESTINATION="user@server.example.com"

# Порт на СЕРВЕРЕ, через который будет доступна станция
# (ssh -R 127.0.0.1:<TUNNEL_PORT>:127.0.0.1:22 ...)
TUNNEL_PORT=2232

# Дополнительные SSH-опции (IPv4, agent forwarding и пр.)
SSH_EXTRA_OPTS=""

# Jump-хост (опционально). Используется ProxyCommand для совместимости
# с OpenSSH 8.x (флаг -J пробрасывает -R в подпроцесс — баг).
# Примеры:
#   SSH_JUMP_HOST="root@nlproxy"
#   SSH_JUMP_HOST="user@jumphost.example.com"
#   SSH_JUMP_HOST="user@jumphost:2200"
SSH_JUMP_HOST=""
