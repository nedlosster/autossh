# auto-ssh-tunnels -- менеджер SSH-туннелей
# Скопируй в config.yml и отредактируй.
#
# Команды:
#   auto-ssh-tunnels full              Установка / применение конфига
#   auto-ssh-tunnels dry-run           Предпросмотр генерируемых файлов
#   auto-ssh-tunnels status            Статус сервисов и проверка портов
#   auto-ssh-tunnels restart [name]    Перезапуск туннелей (все или один)
#   auto-ssh-tunnels copy-key <name>   Копировать SSH-ключ на сервер
#
# После изменения config.yml повторно запусти:
#   sudo auto-ssh-tunnels full
# Скрипт идемпотентен: перезапустит только изменённые сервисы.
#
# Из исходников вместо auto-ssh-tunnels используй bash setup.sh.

tunnel_user: autosshtunnels       # Системный пользователь для autossh
log_dir: /var/log/ssh-tunnel

defaults:
  keepalive_interval: 30          # ServerAliveInterval
  keepalive_count: 3              # ServerAliveCountMax
  restart_delay: 10               # RestartSec в systemd
  monitor_interval: 120           # Интервал watchdog (сек)
  monitor_max_failures: 3         # Кол-во ошибок до рестарта

connections:
  - name: prod
    server: admin@203.0.113.10:22
    args: "-R 10080:127.0.0.1:80 -R 10443:127.0.0.1:443 -L 3129:127.0.0.1:3128"
    jump: "root@bastion:2200"     # Опционально

  - name: backup
    server: deploy@198.51.100.20
    args: "-R 10022:127.0.0.1:22 -A"
